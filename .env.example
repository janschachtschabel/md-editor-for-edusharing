# ── edu-sharing repository ─────────────────────────────────────────
# Base URL (without /edu-sharing). Default = WLO staging.
EDU_REPO_BASE_URL=https://repository.staging.openeduhub.net

# Optional service-account fallback with write access. Normally not needed:
# users log in with their own WLO account and saving uses their session.
EDU_USER=
EDU_PASS=

# ── Server ─────────────────────────────────────────────────────────
PORT=3000

# Repo write buffering: earliest X ms after the last change / at the
# latest every Y ms while typing continuously.
SAVE_DEBOUNCE_MS=15000
SAVE_MAX_DEBOUNCE_MS=90000

# ── Cross-origin embedding (optional) ──────────────────────────────
# Comma-separated list of allowed origins for CORS + WebSocket, or '*'.
# Empty = same-origin only (all-in-one Docker deployment, the standard).
# Only needed when the UI/component is served from a different origin
# than the collab server (e.g. embedded in an edu-sharing page).
# Prefer explicit origins; '*' allows ANY site to embed and connect.
# Example: ALLOWED_ORIGINS=https://repository.staging.openeduhub.net
ALLOWED_ORIGINS=

# Number of trusted reverse-proxy hops (0 = direct, 1 = behind one proxy).
# Never "trust all": clients could spoof their IP and bypass rate limits.
TRUST_PROXY_HOPS=0

# ── Rate limiting / timeouts ───────────────────────────────────────
# Login attempts per client IP within the window (brute-force guard).
LOGIN_RATE_MAX=10
LOGIN_RATE_WINDOW_MS=300000
# Timeout for every edu-sharing REST call (ms).
EDU_TIMEOUT_MS=15000
# Sliding TTL of server-side login sessions (ms). Default: 8 hours.
SESSION_TTL_MS=28800000

# ── AI auto-tagging (optional, B-API OpenAI passthrough) ───────────
# Without a key the 🤖 button stays hidden. WLO convention: the key lives in
# the OS user environment as B_API_KEY / B_API_KEY_STAGING (NOT in .env);
# AI_API_KEY is the explicit override for deployments (masked CI variable).
# AI_API_KEY=
# Chat model on the passthrough (default: gpt-5.4-mini).
# AI_MODEL=gpt-5.4-mini
# Base URL is DERIVED from EDU_REPO_BASE_URL (repository.X → b-api.X
# /api/v1/llm/openai). Override only for non-standard setups:
# AI_BASE_URL=
# Timeout for one model call in ms (long texts take a while).
# AI_TIMEOUT_MS=90000

# ── Local development only — NEVER in a deployment ─────────────────
# Allows editing without login (saving still requires a session).
# ALLOW_ANONYMOUS_EDIT=true
